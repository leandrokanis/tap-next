{
  "name": "tick longo cascateia work cronometrado e rest, parando na Preparação",
  "workout": {
    "version": 1,
    "name": "Core",
    "exercises": [
      {
        "name": "Prancha",
        "mode": "time",
        "sets": 3,
        "duration": 30,
        "restBetweenSets": 15
      }
    ]
  },
  "steps": [
    {
      "at": 0,
      "event": "start"
    },
    {
      "at": 0,
      "event": "next"
    },
    {
      "at": 200,
      "event": "tick"
    },
    {
      "expect": {
        "phase": "prepare",
        "setNumber": 2,
        "overtime": 152,
        "completedSets": 1,
        "lastSet": {
          "setIndex": 1,
          "durationSeconds": 30
        }
      }
    }
  ]
}
