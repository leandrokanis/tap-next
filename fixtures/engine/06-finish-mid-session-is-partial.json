{
  "name": "encerrar no meio congela a duração e não completa as fases",
  "workout": {
    "version": 1,
    "name": "Full body",
    "exercises": [
      { "name": "Remada", "mode": "reps", "sets": 3, "reps": 10, "restBetweenSets": 60 },
      { "name": "Prancha", "mode": "time", "sets": 3, "duration": 30, "restBetweenSets": 15 }
    ]
  },
  "steps": [
    { "at": 0, "event": "start" },
    { "at": 35, "event": "next" },
    { "expect": { "phase": "rest", "remaining": 60 } },
    { "at": 95, "event": "tick" },
    { "expect": { "status": "running", "phase": "rest", "remaining": 0, "overtime": 0 } },
    { "at": 95, "event": "next" },
    { "expect": { "phase": "work", "setNumber": 2 } },
    { "at": 130, "event": "next" },
    { "expect": { "phase": "rest", "completedSets": 2 } },
    { "at": 150, "event": "finish" },
    { "expect": { "status": "finished", "phase": "done", "completedAll": false, "completedSets": 2, "sessionElapsed": 150 } }
  ]
}
