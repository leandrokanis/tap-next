{
  "name": "pausa congela o relógio, next é ignorado pausado, resume desloca a fase",
  "workout": {
    "version": 1,
    "name": "Pernas A",
    "exercises": [
      { "name": "Agachamento", "mode": "reps", "sets": 2, "reps": 10, "restBetweenSets": 90 }
    ]
  },
  "steps": [
    { "at": 0, "event": "start" },
    { "at": 30, "event": "next" },
    { "expect": { "phase": "rest", "remaining": 90 } },
    { "at": 40, "event": "tick" },
    { "expect": { "phase": "rest", "remaining": 80 } },
    { "at": 50, "event": "pause" },
    { "expect": { "status": "paused", "phase": "rest", "remaining": 70, "elapsed": 20 } },
    { "at": 500, "event": "tick" },
    { "expect": { "status": "paused", "phase": "rest", "remaining": 70 } },
    { "at": 505, "event": "next" },
    { "expect": { "status": "paused", "phase": "rest", "remaining": 70, "completedSets": 1 } },
    { "at": 510, "event": "resume" },
    { "expect": { "status": "running", "phase": "rest", "remaining": 70 } },
    { "at": 520, "event": "tick" },
    { "expect": { "phase": "rest", "remaining": 60, "sessionElapsed": 60 } },
    { "at": 580, "event": "tick" },
    { "expect": { "phase": "work", "setNumber": 2, "elapsed": 0, "sessionElapsed": 120 } }
  ]
}
