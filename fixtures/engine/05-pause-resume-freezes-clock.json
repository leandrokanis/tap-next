{
  "name": "pausa congela cronômetros na execução e o overtime na Preparação",
  "workout": {
    "version": 1,
    "name": "Pernas A",
    "exercises": [
      {
        "name": "Agachamento",
        "mode": "reps",
        "sets": 3,
        "reps": 10,
        "weight": 60,
        "restBetweenSets": 90
      }
    ]
  },
  "steps": [
    {
      "at": 0,
      "event": "start"
    },
    {
      "at": 5,
      "event": "next"
    },
    {
      "at": 20,
      "event": "pause"
    },
    {
      "expect": {
        "status": "paused",
        "phase": "work",
        "elapsed": 15
      }
    },
    {
      "at": 50,
      "event": "resume"
    },
    {
      "at": 65,
      "event": "next"
    },
    {
      "expect": {
        "phase": "rest",
        "sessionElapsed": 35,
        "completedSets": 1
      }
    },
    {
      "at": 155,
      "event": "tick"
    },
    {
      "expect": {
        "phase": "prepare",
        "setNumber": 2,
        "overtime": 0
      }
    },
    {
      "at": 160,
      "event": "pause"
    },
    {
      "expect": {
        "status": "paused",
        "overtime": 5
      }
    },
    {
      "at": 200,
      "event": "resume"
    },
    {
      "expect": {
        "status": "running",
        "overtime": 5
      }
    },
    {
      "at": 210,
      "event": "tick"
    },
    {
      "expect": {
        "phase": "prepare",
        "overtime": 15
      }
    }
  ]
}
