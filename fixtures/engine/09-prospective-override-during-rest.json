{
  "name": "ajuste no descanso vale para o PRÓXIMO set (prospectivo, marca adjusted)",
  "workout": {
    "version": 1,
    "name": "Pernas A",
    "exercises": [
      { "name": "Agachamento", "mode": "reps", "sets": 3, "reps": 10, "weight": 60, "restBetweenSets": 90 }
    ]
  },
  "steps": [
    { "at": 0, "event": "start" },
    { "at": 40, "event": "next" },
    { "expect": { "phase": "rest", "completedSets": 1, "lastSet": { "setIndex": 1, "reps": 10, "weight": 60 } } },
    { "at": 50, "event": "setOverride", "reps": 8, "weight": 55 },
    { "expect": { "phase": "rest", "completedSets": 1, "lastSet": { "setIndex": 1, "reps": 10, "weight": 60 } } },
    { "at": 60, "event": "next" },
    { "expect": { "phase": "work", "setNumber": 2, "completedSets": 1 } },
    { "at": 100, "event": "next" },
    { "expect": { "phase": "rest", "completedSets": 2, "lastSet": { "setIndex": 2, "reps": 8, "weight": 55, "adjusted": true } } },
    { "at": 110, "event": "next" },
    { "expect": { "phase": "work", "setNumber": 3 } },
    { "at": 150, "event": "next" },
    { "expect": { "status": "finished", "completedAll": true, "completedSets": 3, "lastSet": { "setIndex": 3, "reps": 10, "weight": 60 } } }
  ]
}
