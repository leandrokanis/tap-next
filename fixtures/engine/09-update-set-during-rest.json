    { "expect": { "phase": "rest", "lastSet": { "setIndex": 1, "reps": 8, "weight": 55 } } },
    { "at": 130, "event": "tick" },
    { "expect": { "phase": "work", "setNumber": 2 } },
    { "at": 160, "event": "next" },
    { "expect": { "status": "finished", "completedSets": 2, "lastSet": { "setIndex": 2, "reps": 10, "weight": 60 } } }
  ]
