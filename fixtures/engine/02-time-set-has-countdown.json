{
  "name": "série de tempo: Iniciar dispara 3-2-1; contagem não conta no tempo da série",
  "workout": {
    "version": 1,
    "name": "Core",
    "exercises": [
      {
        "name": "Prancha",
        "mode": "time",
        "sets": 3,
        "duration": 30,
        "restBetweenSets": 15
      }
    ]
  },
  "steps": [
    {
      "at": 0,
      "event": "start"
    },
    {
      "expect": {
        "phase": "prepare",
        "setNumber": 1
      }
    },
    {
      "at": 10,
      "event": "next"
    },
    {
      "expect": {
        "phase": "work",
        "countdown": 3,
        "remaining": 30,
        "elapsed": 0
      }
    },
    {
      "at": 12,
      "event": "tick"
    },
    {
      "expect": {
        "phase": "work",
        "countdown": 1,
        "remaining": 30
      }
    },
    {
      "at": 20,
      "event": "tick"
    },
    {
      "expect": {
        "phase": "work",
        "countdown": 0,
        "elapsed": 7,
        "remaining": 23
      }
    },
    {
      "at": 43,
      "event": "tick"
    },
    {
      "expect": {
        "phase": "rest",
        "remaining": 15,
        "completedSets": 1,
        "lastSet": {
          "setIndex": 1,
          "durationSeconds": 30
        }
      }
    },
    {
      "at": 58,
      "event": "tick"
    },
    {
      "expect": {
        "phase": "prepare",
        "setNumber": 2,
        "overtime": 0
      }
    },
    {
      "at": 70,
      "event": "tick"
    },
    {
      "expect": {
        "phase": "prepare",
        "setNumber": 2,
        "overtime": 12
      }
    }
  ]
}
