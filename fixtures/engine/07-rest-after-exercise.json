{
  "name": "descanso após o exercício desemboca na Preparação do próximo exercício",
  "workout": {
    "version": 1,
    "name": "Costas",
    "exercises": [
      {
        "name": "Remada",
        "mode": "reps",
        "sets": 1,
        "reps": 12,
        "restAfterExercise": 60
      },
      {
        "name": "Serrote",
        "mode": "reps",
        "sets": 1,
        "reps": 10
      }
    ]
  },
  "steps": [
    {
      "at": 0,
      "event": "start"
    },
    {
      "expect": {
        "phase": "prepare",
        "exercise": "Remada"
      }
    },
    {
      "at": 0,
      "event": "next"
    },
    {
      "at": 30,
      "event": "next"
    },
    {
      "expect": {
        "phase": "rest",
        "remaining": 60
      }
    },
    {
      "at": 90,
      "event": "tick"
    },
    {
      "expect": {
        "phase": "prepare",
        "exercise": "Serrote",
        "setNumber": 1,
        "overtime": 0
      }
    },
    {
      "at": 100,
      "event": "next"
    },
    {
      "at": 130,
      "event": "next"
    },
    {
      "expect": {
        "status": "finished",
        "completedAll": true,
        "completedSets": 2
      }
    }
  ]
}
