{
  "name": "isometria avança sozinha ao fim do tempo (após leadin); descanso segura em overtime",
  "workout": {
    "version": 1,
    "name": "Fisio core",
    "exercises": [
      { "name": "Prancha", "mode": "time", "sets": 2, "duration": 30, "restBetweenSets": 15 }
    ]
  },
  "steps": [
    { "at": 0, "event": "start" },
    { "expect": { "status": "running", "phase": "leadin", "exercise": "Prancha", "setNumber": 1, "remaining": 3 } },
    { "at": 3, "event": "tick" },
    { "expect": { "phase": "work", "exercise": "Prancha", "setNumber": 1, "remaining": 30, "elapsed": 0 } },
    { "at": 32, "event": "tick" },
    { "expect": { "phase": "work", "setNumber": 1, "elapsed": 29, "remaining": 1 } },
    { "at": 34, "event": "tick" },
    { "expect": { "phase": "rest", "setNumber": 1, "remaining": 14, "overtime": 0, "completedSets": 1, "lastSet": { "exercise": "Prancha", "setIndex": 1, "durationSeconds": 30 } } },
    { "at": 48, "event": "tick" },
    { "expect": { "status": "running", "phase": "rest", "remaining": 0, "overtime": 0 } },
    { "at": 53, "event": "tick" },
    { "expect": { "status": "running", "phase": "rest", "remaining": 0, "overtime": 5 } },
    { "at": 53, "event": "next" },
    { "expect": { "phase": "leadin", "setNumber": 2, "remaining": 3, "elapsed": 0 } },
    { "at": 56, "event": "tick" },
    { "expect": { "phase": "work", "setNumber": 2, "remaining": 30, "elapsed": 0 } },
    { "at": 86, "event": "tick" },
    { "expect": { "status": "finished", "phase": "done", "completedAll": true, "completedSets": 2, "sessionElapsed": 80, "lastSet": { "setIndex": 2, "durationSeconds": 30 } } }
  ]
}
