{
  "expo": {
    "name": "Tap Next",
    "slug": "tap-next",
    "version": "0.1.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.leandrokanis.tapnext",
      "supportsTablet": false,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "plugins": [
      "expo-sqlite",
      "expo-localization",
      [
        "expo-notifications",
        {
          "defaultChannel": "default"
        }
      ],
      "expo-audio",
      "expo-font"
    ]
  }
}
